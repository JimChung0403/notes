{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright-local": {
      "type": "local",
      "command": [
        "node",
        "./node_modules/@playwright/mcp/cli.js",
        "--config",
        "./tools/playwright-mcp.config.json"
      ],
      "enabled": true
    }
  }
}
